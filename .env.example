# Application
APP_NAME=growthpath
NODE_ENV=development
LOG_LEVEL=info

# Scan engine credentials
GOOGLE_API_KEY=your-google-api-key
SERP_API_KEY=your-serpapi-key
YELP_API_KEY=your-yelp-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
CENSUS_API_KEY=your-census-api-key
DFS_LOGIN=your-dataforseo-login
DFS_PASSWORD=your-dataforseo-password
MOZ_API_KEY=your-moz-token-or-base64-legacy-credentials

# Use mock scan data locally (no external API calls). Set false when keys above are configured.
SCAN_MOCK=true

# API
API_HOST=0.0.0.0
API_PORT=3001
CORS_ORIGIN=http://localhost:5173

# Local Docker host ports (avoid conflicts with other stacks on this machine)
MONGO_HOST_PORT=27118
RABBITMQ_HOST_PORT=5674
RABBITMQ_MGMT_HOST_PORT=15674
MINIO_API_HOST_PORT=9004
MINIO_CONSOLE_HOST_PORT=9005

# MongoDB (auth enabled in docker-compose.local.yml)
MONGO_ROOT_USER=growthpath
MONGO_ROOT_PASSWORD=generate-a-unique-password
MONGODB_URI=mongodb://growthpath:generate-a-unique-password@127.0.0.1:27118/growthpath?authSource=admin

# RabbitMQ
RABBITMQ_USER=growthpath
RABBITMQ_PASSWORD=generate-a-unique-password
RABBITMQ_URL=amqp://growthpath:generate-a-unique-password@127.0.0.1:5674
RABBITMQ_PREFETCH=10

# MinIO / S3
S3_ENDPOINT=http://127.0.0.1:9004
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=generate-a-unique-access-key
S3_SECRET_ACCESS_KEY=generate-a-unique-secret-key
S3_BUCKET=growthpath
S3_FORCE_PATH_STYLE=true

# Auth / seed
SESSION_SECRET=generate-a-unique-session-secret-at-least-32-chars
SEED_ADMIN_EMAIL=admin@example.com
# Prefer a bcrypt hash (node scripts/hash-seed-admin-password.mjs <password>)
SEED_ADMIN_PASSWORD_HASH=
# Plaintext fallback for local seed only (omit when using SEED_ADMIN_PASSWORD_HASH)
SEED_ADMIN_PASSWORD=

# Sample scan seed (Kitchen 747 demo for UI review)
SEED_SAMPLE_USER_EMAIL=davex814@gmail.com
SEED_SAMPLE_USER_PASSWORD_HASH=
SEED_SAMPLE_USER_PASSWORD=

# UI (Vite)
VITE_API_URL=http://localhost:3001

# Production domain (Nginx / Certbot)
DEFAULT_DOMAIN=growthpath.example.com
CERTBOT_EMAIL=admin@example.com

# Docker image build / deploy
REGISTRY=ghcr.io
IMAGE_NAMESPACE=growthpath
IMAGE_PREFIX=growthpath
TAG=latest
PUSH=false
PUSH_LATEST=true
PLATFORMS=linux/amd64,linux/arm64

# Production service URLs (rewrite-prod-uris.mjs converts hosts for docker-compose.prod.yml)
# MONGODB_URI=mongodb://growthpath:password@mongo:27017/growthpath?authSource=admin
# RABBITMQ_URL=amqp://growthpath:password@rabbitmq:5672
# S3_ENDPOINT=http://minio:9000
